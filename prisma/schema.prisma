generator client {
  provider = "prisma-client-js"
}

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  first_name String
  last_name  String
  email      String   @unique
  password   String
  role       String   @default("user")
  shops      Shop[]
  orders     Order[]
  reviews    Review[]
}

model Shop {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  shop_name   String
  address     String
  contact_no  String
  user        User       @relation(fields: [userId], references: [id])
  userId      String     @db.ObjectId
  autoParts   AutoPart[]
}

model AutoPart {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  part_name   String
  category    String
  price       Float
  quantity    Int
  description String?     // @db.Text hata diya kyunki MongoDB ise support nahi karta
  shop        Shop        @relation(fields: [shopId], references: [id])
  shopId      String      @db.ObjectId
  images      PartImage[]
  orderItems  OrderItem[]
}

model PartImage {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl   String
  autoPart   AutoPart @relation(fields: [autoPartId], references: [id])
  autoPartId String   @db.ObjectId
}

model Order {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  order_date  DateTime    @default(now())
  total_price Float
  status      String      @default("pending")
  user        User        @relation(fields: [userId], references: [id])
  userId      String      @db.ObjectId
  orderItems  OrderItem[]
  payment     Payment?
}

model OrderItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  quantity   Int
  price      Float
  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String   @db.ObjectId
  autoPart   AutoPart @relation(fields: [autoPartId], references: [id])
  autoPartId String   @db.ObjectId
}

model Payment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  payment_date   DateTime @default(now())
  amount         Float
  payment_method String
  status         String   @default("completed")
  order          Order    @relation(fields: [orderId], references: [id])
  orderId        String   @unique @db.ObjectId
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  rating     Int
  comment    String?  // @db.Text hata diya
  user       User     @relation(fields: [userId], references: [id])
  userId     String   @db.ObjectId
}